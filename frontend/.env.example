# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
# Server-side only (used in getServerSideProps / API routes)
API_URL=http://localhost:4000
PYTHON_API_URL=http://localhost:8000

# Client-side (exposed to browser — must have NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=OMEN
