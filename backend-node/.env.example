# ─── Node API ─────────────────────────────────────────────────────────────────
PORT=4000

# SQLite
DB_URL=./omen.db

# Redis (not required — using in-memory cache)
# REDIS_URL=redis://localhost:6379

# JWT — change to a long random string in production
JWT_SECRET=change_me_to_a_secure_random_string_min_32_chars

# Python scanning service
PYTHON_API_URL=http://localhost:8000
